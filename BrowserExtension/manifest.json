{
  "manifest_version": 3,
  "name": "Claude Usage HUD",
  "version": "1.0.0",
  "description": "Sends your Claude.ai session usage percentage to the Claude Usage HUD macOS menu bar app.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://localhost:27420/*",
    "http://127.0.0.1:27420/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage HUD"
  }
}
